<Window x:Class="AzuHelper_v2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AzuHelper_v2"
        mc:Ignorable="d"
        Title="AzuHelper V2 - Time Tracking" Height="750" Width="1000" ResizeMode="NoResize"
        Background="{StaticResource Brush.Bg}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" Padding="16" Margin="0,0,0,14">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="26" FontWeight="SemiBold" Text="AzuHelper" />
                    <TextBlock Margin="0,4,0,0" Foreground="{StaticResource Brush.TextMuted}" Text="Time Tracking" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Update" Command="{Binding CheckUpdateCommand}" Margin="0,0,10,0" />
                        <Button Content="Settings" Command="{Binding OpenSettingsCommand}" />
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource Brush.TextMuted}"
                               Text="{Binding UpdateStatusText}"
                               Visibility="{Binding HasUpdateStatus, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Quickfill" Command="{Binding QuickFillCommand}" Style="{StaticResource AccentButton}" />
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding WeekLabel}" />
                <TextBlock Margin="12,0,0,0" Foreground="Tomato" Text="{Binding QuickFillError}" Visibility="{Binding HasQuickFillError, Converter={StaticResource BoolToVisibility}}" />
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,63,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Text="On" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Text="Day" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Text="Start" />
                    <TextBlock Grid.Column="3" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Text="End" />
                    <TextBlock Grid.Column="4" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextMuted}" Text="Duration" />
                </Grid>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Days}" Margin="0,0,0,10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Brush.Surface2}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="2" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding Enabled, Mode=TwoWay}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" VerticalAlignment="Center">
                                    <Run Text="{Binding DayName}" />
                                    <Run Text=" " />
                                    <Run Text="{Binding DateLabel, Mode=OneWay}" />
                                    </TextBlock>

                                    <TextBox Grid.Column="2" Text="{Binding StartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                    <TextBox Grid.Column="3" Text="{Binding EndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="4" Text="{Binding Duration}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource Brush.Surface}" BorderBrush="{StaticResource Brush.Border}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource Brush.TextMuted}" Text="To" Margin="0,0,0,6" />
                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding MailTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />

                <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{StaticResource Brush.TextMuted}" Text="CC" Margin="0,0,0,6" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MailCc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0" />

                <CheckBox Grid.Row="1" Grid.Column="2" IsChecked="{Binding OpenInOutlook, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" Content="Open in Outlook" />
                <Button Grid.Row="1" Grid.Column="3" Style="{StaticResource AccentButton}" Command="{Binding CreateEmailCommand}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Create &amp; Send Email" HorizontalAlignment="Center" />
                        <ProgressBar Grid.Row="1" Height="4" Minimum="0" Maximum="100"
                                     Margin="0,6,0,0"
                                     Value="{Binding EmailProgress, Mode=OneWay}"
                                     Background="{StaticResource Brush.Surface2}" Foreground="{StaticResource Brush.Accent}" BorderThickness="0"
                                     Visibility="{Binding IsCreatingEmail, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                </Button>

            </Grid>
        </Border>
    </Grid>
</Window>
